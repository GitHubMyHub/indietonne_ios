type Metrics {
  latestUsers: [PlatformUser!]!

  totalUsers: Long!

  totalSubscriptions: Long!

  syncedSchedules: Int!

  totalStreets: Long!

  totalPlaces: Long!

  totalDistricts: Long!

  totalFractions: Long!

  appointmentsPerPlace: [AppointmentsPerPlace!]!
}

type Mutation {
  savePlace(place: PlaceInput!, placeLogo: Upload, placeBanner: Upload): Place!

  deletePlaces(placeIds: [UUID!]!): [Place!]!

  saveStreets(saveStreetsInput: SaveStreetsInput!): [Street!]!

  deleteStreets(streetIds: [UUID!]!): [Street!]!

  saveUser(saveUserInput: SaveUserInput!): PlatformUser!

  saveAdminUser(saveUserInput: SaveUserAdminInput!): PlatformUser!

  deleteUsers(userIds: [UUID!]!): [PlatformUser!]!

  signUp(loginUser: SignUpInput!): String!

  requestPasswordReset(email: String!): String!

  resetPassword(input: ResetPasswordInput!): String!

  verifyEmail(token: String!): String!

  resendVerificationEmail(email: String!): String!

  schedule(scheduleAppointment: ScheduleDataInput!): PlatformUserPlace!

  deleteAppointmentSchedule(appointmentId: UUID!): PlatformUserPlace!

  savePlatformUserPlace(savePlatformUserPlaceInput: SavePlatformUserPlaceInput!): PlatformUserPlace!

  deletePlatformUserPlaces(platformUserPlaceIds: [UUID!]!): [PlatformUserPlace!]!

  savePlannedAppointment(savePlannedAppointmentInput: SavePlannedAppointmentInput!): PlannedAppointment!

  savePlannedAppointments(savePlannedAppointmentsInput: [SavePlannedAppointmentInput!]!): [PlannedAppointment!]!

  deletePlannedAppointments(plannedAppointmentIds: [UUID!]!): [PlannedAppointment!]!

  sendNotification(note: NoteInput!, token: String!): String
}

input NoteInput {
  title: String

  body: String

  image: String
}

enum Origin {
  PLACE_LOGO

  PLACE_BANNER
}

input PaginationInput {
  page: Int

  size: Int
}

