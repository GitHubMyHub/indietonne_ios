}

type PlatformUserPlacePaginated {
  content: [PlatformUserPlace!]!

  totalPages: Int!

  totalElements: Int!

  number: Int!

  size: Int!
}

type Query {
  places(pagination: PaginationInput): PlacePaginated!

  place(placeId: UUID!): Place!

  streets(pagination: PaginationInput!, filter: StreetFiler!): StreetPaginated!

  findStreets(pagination: PaginationInput!, search: String!): StreetPaginated!

  districts(pagination: PaginationInput!, placeId: String): DistrictPaginated!

  signIn(loginUser: LoginInput!): String!

  appointments(pagination: PaginationInput!): PlatformUserPlacePaginated!

  platformUserPlaces(pagination: PaginationInput!): PlatformUserPlacePaginated!

  users(pagination: PaginationInput!): UserPaginated!

  usersAdmin(pagination: PaginationInput!): UserPaginatedAdmin!

  user(userId: UUID!): PlatformUser!

  plannedAppointments(pagination: PaginationInput!): PlannedAppointmentPaginated!

  groupedPlannedAppointments(placeId: UUID!, pagination: PaginationInput!): TestoPaginated!

  metrics: Metrics!

  init: String!
}

input ResetPasswordInput {
  token: String!

  newPassword: String!
}

enum Role {
  ADMIN

  MODERATOR

  USER
}

