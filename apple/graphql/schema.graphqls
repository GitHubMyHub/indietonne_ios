type Appointment {
  id: UUID!

  platformUserPlace: PlatformUserPlace!

  appointmentDate: Instant!

  scheduledDate: Instant!

  interval: Int!

  repetition: Int!

  alarm: Boolean!

  notify: Boolean!

  active: Boolean!

  fractions: [Fraction!]!
}

